#this imports the module needed to create a socket.
import socket
#this sets my host and port values.
HOST = "127.0.0.1"
PORT = 5000
#this defines my function for the server
def start_server():
    server_socket = None

    try:
        # PSEUDOCODE: create and configure server socket
        server_socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        server_socket.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        server_socket.bind((HOST, PORT))
        server_socket.listen(5)

        # PSEUDOCODE: set timeout so accept() doesn't block forever (allows Ctrl+C)
        server_socket.settimeout(1)

        print(f"Server is listening on {HOST}:{PORT}...")

        # PSEUDOCODE: main loop runs until interrupted by user
        while True:
            client_socket = None
            client_address = None
            try:
                try:
                    # PSEUDOCODE: wait for incoming connection (with timeout)
                    client_socket, client_address = server_socket.accept()
                except socket.timeout:
                    # PSEUDOCODE: no connection received within timeout, loop again
                    # allows program to check for KeyboardInterrupt
                    continue

                print(f"Connection from {client_address} has been established.")
                data = client_socket.recv(1024)

                if not data:
                    print("No data received.")
                    continue

                try:
                    message = data.decode("utf-8")
                except UnicodeDecodeError:
                    print("Received data could not be decoded.")
                    continue

                print(f"Received message: {message}")
                response = f"Server received: {message} from {client_address}"

                try:
                    client_socket.sendall(response.encode("utf-8"))
                except ConnectionResetError:
                    print("Connection was reset.")
                except OSError as e:
                    print(f"OS error occurred: {e}")

            finally:
                if client_socket:
                    client_socket.close()
                    if client_address:
                        print(f"Connection with {client_address} closed.")

    except KeyboardInterrupt:
        # PSEUDOCODE: user pressed Ctrl+C, exit loop and shut down cleanly
        print("\nKeyboardInterrupt received. Shutting down server gracefully...")

    finally:
        # PSEUDOCODE: always close server socket before exiting
        if server_socket:
            server_socket.close()
            print("Server socket closed.")

if __name__ == "__main__":
    start_server()
